# Application
APP_NAME=lead-recovery
APP_ENVIRONMENT=development
APP_PORT=3000
NODE_ENV=development

# CRM
CRM_ADAPTER=file
CRM_BASE_URL=
CRM_API_KEY_ENV_VAR=CRM_API_KEY
CRM_TIMEOUT=5000
CRM_SUPPORTS_CONTEXT_FUSION=false

# STT
STT_PROVIDER=mock
STT_SARVAM_BASE_URL=https://api.sarvam.ai
STT_SARVAM_API_KEY_ENV_VAR=SARVAM_API_KEY
STT_SARVAM_TIMEOUT_MS=5000
STT_SARVAM_RETRY_429_MS=1200
STT_SARVAM_FALLBACK_TO_MOCK_ON_5XX=true

# TTS
TTS_PROVIDER=mock
TTS_ELEVENLABS_BASE_URL=https://api.elevenlabs.io
TTS_ELEVENLABS_API_KEY_ENV_VAR=ELEVEN_LABS_API_KEY
TTS_ELEVENLABS_TIMEOUT_MS=5000
TTS_ELEVENLABS_CACHE_TTL_DAYS=7
TTS_ELEVENLABS_DEFAULT_VOICE_ID=default

# Telephony
TELEPHONY_PROVIDER=mock
TELEPHONY_PLAYS_WELCOME_ON_CONNECT=false
TELEPHONY_FROM_NUMBER=+910000000000
TWILIO_ACCOUNT_SID_ENV_VAR=TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN_ENV_VAR=TWILIO_AUTH_TOKEN
TWILIO_BASE_URL=https://api.twilio.com
TWILIO_TIMEOUT_MS=5000
EXOTEL_ACCOUNT_SID_ENV_VAR=EXOTEL_ACCOUNT_SID
EXOTEL_AUTH_TOKEN_ENV_VAR=EXOTEL_AUTH_TOKEN
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_TIMEOUT_MS=5000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_CORRELATION_ID_HEADER=X-Correlation-ID
LOG_SINK_CONSOLE=true
LOG_SINK_DATABASE=false

# LLM
LLM_PROVIDER=mock
LLM_HAS_BUILT_IN_DEVIATION=false
LLM_MAX_PROMPT_TOKENS=4000
LLM_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
LLM_GEMINI_MODEL=gemini-1.5-flash
LLM_GEMINI_API_KEY_ENV_VAR=GEMINI_API_KEY
LLM_GEMINI_TIMEOUT_MS=7000

# Outreach
OUTREACH_PREFERRED_CHANNEL=call

# Conversational AI
CONVERSATIONAL_AI_USE_FULL_SERVICE=false

# Analytics
ANALYTICS_ENABLED=true

# Scheduling
SCHEDULING_MAX_CALL_ATTEMPTS=3
SCHEDULING_RETRY_INTERVAL_MINUTES=60

# Security
SECURITY_ENCRYPTION_KEY_ENV_VAR=ENCRYPTION_KEY
JWT_SECRET=

# Actual secret values referenced by the *_ENV_VAR keys above
CRM_API_KEY=
SARVAM_API_KEY=
ELEVEN_LABS_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
EXOTEL_ACCOUNT_SID=
EXOTEL_AUTH_TOKEN=
GEMINI_API_KEY=
ENCRYPTION_KEY=
